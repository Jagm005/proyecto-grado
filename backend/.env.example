# ── Base de datos ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventario
DB_USER=postgres
DB_PASSWORD=postgres

# ── Servidor ───────────────────────────────────────────────────
